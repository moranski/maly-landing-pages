---
interface Item {
	title: string;
	body: string;
}

interface Props {
	items: Item[];
	ordered?: boolean;
}

const { items, ordered = false } = Astro.props;
---

<div class="card-grid">
	{
		items.map((item, index) => (
			<article class="info-card">
				{ordered && <span class="info-card__index">{index + 1}</span>}
				<h3>{item.title}</h3>
				<p>{item.body}</p>
			</article>
		))
	}
</div>

<style>
	.card-grid {
		width: 100%;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
		gap: var(--space-5);
	}

	.info-card {
		position: relative;
		min-height: 190px;
		padding: var(--space-6) var(--space-5);
		border: 4px solid white;
		border-radius: 28px;
		background: linear-gradient(180deg, #ffffff, #fff7de);
		box-shadow: var(--shadow-soft);
		text-align: center;
	}

	.info-card::before {
		content: "✓";
		display: inline-grid;
		width: 2.35rem;
		height: 2.35rem;
		margin-block-end: var(--space-4);
		place-items: center;
		border-radius: 999px;
		background: var(--color-success);
		color: white;
		font-size: 1.3rem;
		font-weight: 900;
	}

	.info-card__index {
		display: inline-grid;
		width: 2.6rem;
		height: 2.6rem;
		margin-block-end: var(--space-4);
		place-items: center;
		border-radius: 999px;
		background: var(--color-secondary);
		color: var(--color-text-inverse);
		font-weight: 900;
	}

	.info-card:has(.info-card__index)::before {
		display: none;
	}

	.info-card h3 {
		margin: 0 0 var(--space-3);
		color: var(--color-ink);
		font-size: 1.28rem;
		line-height: 1.24;
	}

	.info-card p {
		margin: 0;
		color: var(--color-text-muted);
		font-size: 1.02rem;
	}
</style>
