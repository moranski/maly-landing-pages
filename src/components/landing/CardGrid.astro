---
interface Item {
	title: string;
	body: string;
}

interface Props {
	items: Item[];
	ordered?: boolean;
}

const { items, ordered = false } = Astro.props;
---

<div class="card-grid">
	{
		items.map((item, index) => (
			<article class="info-card">
				{ordered && <span class="info-card__index">{index + 1}</span>}
				<h3>{item.title}</h3>
				<p>{item.body}</p>
			</article>
		))
	}
</div>

<style>
	.card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 250px), 1fr));
		gap: var(--space-4);
	}

	.info-card {
		min-height: 180px;
		padding: var(--space-5);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-card);
		background: var(--color-surface);
		box-shadow: var(--shadow-soft);
	}

	.info-card__index {
		display: inline-grid;
		width: 2rem;
		height: 2rem;
		margin-block-end: var(--space-4);
		place-items: center;
		border-radius: 999px;
		background: var(--color-accent);
		color: var(--color-text-inverse);
		font-weight: 800;
	}

	.info-card h3 {
		margin: 0 0 var(--space-3);
		font-size: 1.2rem;
		line-height: 1.3;
	}

	.info-card p {
		margin: 0;
		color: var(--color-text-muted);
		font-size: 1rem;
	}
</style>
