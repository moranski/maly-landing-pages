---
interface Props {
	title: string;
	body: string;
	includes: string[];
	priceHeadline: string;
	priceTotal: string;
	cta: {
		label: string;
		href: string;
	};
}

const { title, body, includes, priceHeadline, priceTotal, cta } = Astro.props;
---

<section id="offer" class="offer">
	<div class="offer__inner">
		<div>
			<p class="kicker">ההצטרפות כוללת</p>
			<h2>{title}</h2>
			<p>{body}</p>
			<ul class="check-list">
				{includes.map((item) => <li>{item}</li>)}
			</ul>
		</div>
		<aside class="price-box" aria-label="מחיר הקורס">
			<p>{priceHeadline}</p>
			<strong>{priceTotal}</strong>
			<a class="button button--primary" href={cta.href}>{cta.label}</a>
		</aside>
	</div>
</section>

<style>
	.offer {
		padding: var(--space-section) var(--space-page);
		background:
			radial-gradient(circle at 15% 12%, rgba(255, 215, 63, 0.35), transparent 18rem),
			radial-gradient(circle at 82% 78%, rgba(255, 63, 143, 0.22), transparent 20rem),
			linear-gradient(135deg, #2b1d67, #167fa5);
	}

	.offer__inner {
		width: min(100%, var(--layout-width));
		margin-inline: auto;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(300px, 0.4fr);
		gap: var(--space-8);
		align-items: start;
		padding: clamp(1rem, 3vw, 2rem);
		border: 5px solid rgba(255, 255, 255, 0.36);
		border-radius: 34px;
		background: rgba(255, 255, 255, 0.12);
		box-shadow: var(--shadow-lift);
		backdrop-filter: blur(8px);
	}

	.offer h2 {
		margin: 0 0 var(--space-5);
		color: var(--color-text-inverse);
		font-size: clamp(2rem, 1.7rem + 1.4vw, 3.1rem);
		line-height: 1.12;
	}

	.offer p {
		margin: 0;
		color: rgba(255, 255, 255, 0.86);
		font-size: 1.15rem;
	}

	.check-list {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
		gap: var(--space-3);
		margin: var(--space-6) 0 0;
		padding: 0;
		list-style: none;
	}

	.check-list li {
		position: relative;
		padding: var(--space-4) var(--space-7) var(--space-4) var(--space-4);
		border: 3px solid rgba(255, 255, 255, 0.78);
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.92);
		box-shadow: var(--shadow-soft);
		color: var(--color-ink);
		font-weight: 800;
	}

	.check-list li::before {
		content: "";
		position: absolute;
		inset-inline-start: var(--space-4);
		inset-block-start: 1.25rem;
		width: 1.05rem;
		height: 1.05rem;
		border-radius: 999px;
		background: var(--color-success);
	}

	.price-box {
		position: sticky;
		top: var(--space-4);
		display: grid;
		gap: var(--space-4);
		padding: var(--space-6);
		border: 5px solid white;
		border-radius: 30px;
		background: linear-gradient(180deg, #fff, #ffe7a8);
		color: var(--color-ink);
		box-shadow: var(--shadow-lift);
		text-align: center;
	}

	.price-box p {
		color: var(--color-accent-strong);
		font-size: 1.28rem;
		font-weight: 900;
	}

	.price-box strong {
		color: var(--color-ink);
		font-size: clamp(2.15rem, 1.7rem + 1.8vw, 3.2rem);
		line-height: 1.15;
	}

	@media (max-width: 900px) {
		.offer__inner {
			grid-template-columns: 1fr;
		}

		.price-box {
			position: static;
		}
	}
</style>
