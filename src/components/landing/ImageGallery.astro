---
interface ImageItem {
	src: string;
	alt: string;
	caption?: string;
}

interface Props {
	images: ImageItem[];
}

const { images } = Astro.props;
---

<div class="image-gallery">
	{
		images.map((image) => (
			<figure>
				<img src={image.src} alt={image.alt} width="1599" height="899" loading="lazy" decoding="async" />
				{image.caption && <figcaption>{image.caption}</figcaption>}
			</figure>
		))
	}
</div>

<style>
	.image-gallery {
		width: 100%;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 270px), 1fr));
		gap: var(--space-5);
	}

	.image-gallery figure {
		margin: 0;
		padding: var(--space-3);
		border: 5px solid white;
		border-radius: 28px;
		background: white;
		box-shadow: var(--shadow-soft);
		transform: rotate(-0.6deg);
	}

	.image-gallery figure:nth-child(even) {
		transform: rotate(0.6deg);
	}

	.image-gallery img {
		width: 100%;
		aspect-ratio: 1599 / 899;
		object-fit: cover;
		border-radius: 20px;
	}

	.image-gallery figcaption {
		margin-block-start: var(--space-3);
		color: var(--color-text-muted);
		font-size: 0.98rem;
		font-weight: 800;
		text-align: center;
	}
</style>
