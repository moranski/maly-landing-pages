---
interface Props {
	src: string;
	alt: string;
	caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="profile-image">
	<div class="profile-image__frame">
		<img src={src} alt={alt} width="572" height="577" loading="lazy" decoding="async" />
	</div>
	{caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
	.profile-image {
		margin: 0;
		display: grid;
		justify-items: center;
		gap: var(--space-3);
	}

	.profile-image__frame {
		width: min(100%, 300px);
		aspect-ratio: 1;
		display: grid;
		place-items: end center;
		overflow: hidden;
		border: 6px solid white;
		border-radius: 50%;
		background:
			radial-gradient(circle at 50% 22%, rgba(255, 215, 63, 0.58), transparent 36%),
			linear-gradient(135deg, #b9effb, #ffe2f0 70%);
		box-shadow: var(--shadow-lift);
	}

	.profile-image img {
		width: 96%;
		height: 96%;
		object-fit: contain;
		object-position: center bottom;
	}

	.profile-image figcaption {
		max-width: 340px;
		margin: 0;
		color: var(--color-text-muted);
		font-size: 1rem;
		font-weight: 800;
		text-align: center;
	}
</style>
