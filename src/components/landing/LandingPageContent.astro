---
interface PageData {
	title: string;
	description: string;
	hero: {
		eyebrow?: string;
		title: string;
		subtitle: string;
		body: string[];
		primaryCta: { label: string; href: string };
		secondaryCta?: { label: string; href: string };
	};
	stats: { value: string; label: string }[];
}

interface Props {
	page: PageData;
}

const { page } = Astro.props;
---

<main>
	<section class="hero">
		<div class="hero__inner">
			<div class="hero__copy">
				{page.hero.eyebrow && <p class="kicker">{page.hero.eyebrow}</p>}
				<h1>{page.hero.title}</h1>
				<p class="hero__subtitle">{page.hero.subtitle}</p>
				<div class="hero__body">
					{page.hero.body.map((paragraph) => <p>{paragraph}</p>)}
				</div>
				<div class="hero__actions">
					<a class="button button--primary" href={page.hero.primaryCta.href}>
						{page.hero.primaryCta.label}
					</a>
					{
						page.hero.secondaryCta && (
							<a class="button button--secondary" href={page.hero.secondaryCta.href}>
								{page.hero.secondaryCta.label}
							</a>
						)
					}
				</div>
			</div>

			<div class="hero__visual" aria-label="מקום לתמונת הקורס העתידית">
				<div class="device-card">
					<div class="device-card__screen">
						<span>English</span>
						<strong>read</strong>
						<span>sound · word · confidence</span>
					</div>
					<div class="device-card__notes">
						<span>A</span>
						<span>sh</span>
						<span>cat</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="stats-strip" aria-label="נתוני הקורס">
		<div class="stats-strip__inner">
			{
				page.stats.map((stat) => (
					<div class="stat">
						<strong>{stat.value}</strong>
						<span>{stat.label}</span>
					</div>
				))
			}
		</div>
	</section>

	<slot />
</main>

<style>
	.hero {
		padding: var(--space-8) var(--space-page) var(--space-10);
		background:
			linear-gradient(135deg, color-mix(in srgb, var(--color-accent-soft) 60%, white), transparent 48%),
			var(--color-surface);
	}

	.hero__inner,
	.stats-strip__inner {
		width: min(100%, var(--layout-width));
		margin-inline: auto;
	}

	.hero__inner {
		display: grid;
		grid-template-columns: minmax(0, 1.04fr) minmax(320px, 0.76fr);
		gap: var(--space-10);
		align-items: center;
		min-height: min(760px, calc(100vh - 72px));
	}

	.hero h1 {
		max-width: 860px;
		margin: 0;
		font-size: clamp(2.45rem, 1.9rem + 2.6vw, 5rem);
		line-height: 1.04;
	}

	.hero__subtitle {
		max-width: 760px;
		margin: var(--space-5) 0 0;
		color: var(--color-text-muted);
		font-size: clamp(1.22rem, 1.1rem + 0.45vw, 1.55rem);
		line-height: 1.5;
	}

	.hero__body {
		max-width: 700px;
		margin-block-start: var(--space-6);
	}

	.hero__body p {
		margin: 0;
	}

	.hero__body p + p {
		margin-block-start: var(--space-4);
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		margin-block-start: var(--space-7);
	}

	.hero__visual {
		min-height: 430px;
		display: grid;
		place-items: center;
	}

	.device-card {
		width: min(100%, 430px);
		padding: var(--space-5);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-card);
		background: var(--color-surface);
		box-shadow: var(--shadow-lift);
		transform: rotate(-2deg);
	}

	.device-card__screen {
		aspect-ratio: 4 / 3;
		display: grid;
		align-content: center;
		gap: var(--space-2);
		padding: var(--space-6);
		border-radius: 8px;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.2)),
			var(--color-accent-soft);
		color: var(--color-ink);
		text-align: left;
		direction: ltr;
	}

	.device-card__screen strong {
		font-size: clamp(3rem, 7vw, 5.7rem);
		line-height: 1;
	}

	.device-card__notes {
		display: flex;
		gap: var(--space-3);
		margin-block-start: var(--space-4);
		direction: ltr;
	}

	.device-card__notes span {
		flex: 1;
		padding: var(--space-3);
		border-radius: 8px;
		background: var(--color-surface-cool);
		color: var(--color-ink);
		font-weight: 800;
		text-align: center;
	}

	.stats-strip {
		padding: 0 var(--space-page);
		background: var(--color-ink);
		color: var(--color-text-inverse);
	}

	.stats-strip__inner {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1px;
		background: color-mix(in srgb, var(--color-text-inverse) 18%, transparent);
	}

	.stat {
		min-height: 130px;
		display: grid;
		align-content: center;
		gap: var(--space-2);
		padding: var(--space-5);
		background: var(--color-ink);
	}

	.stat strong {
		color: var(--color-accent-soft);
		font-size: 2.25rem;
		line-height: 1;
	}

	.stat span {
		color: color-mix(in srgb, var(--color-text-inverse) 78%, transparent);
	}

	@media (max-width: 900px) {
		.hero__inner {
			grid-template-columns: 1fr;
			min-height: auto;
		}

		.hero__visual {
			min-height: 320px;
		}

		.stats-strip__inner {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 560px) {
		.hero {
			padding-block-start: var(--space-6);
		}

		.hero__actions .button {
			width: 100%;
			justify-content: center;
		}

		.hero__visual {
			display: none;
		}

		.stats-strip__inner {
			grid-template-columns: 1fr 1fr;
		}

		.stat {
			min-height: 108px;
			padding: var(--space-4);
		}

		.stat strong {
			font-size: 1.85rem;
		}
	}
</style>
