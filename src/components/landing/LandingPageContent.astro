---
interface PageData {
	title: string;
	description: string;
	hero: {
		eyebrow?: string;
		title: string;
		subtitle: string;
		body: string[];
		primaryCta: { label: string; href: string };
		secondaryCta?: { label: string; href: string };
	};
	stats: { value: string; label: string }[];
}

interface Props {
	page: PageData;
}

const { page } = Astro.props;
---

<main>
	<section class="hero">
		<div class="hero__inner">
			<div class="hero__copy">
				{page.hero.eyebrow && <p class="kicker">{page.hero.eyebrow}</p>}
				<h1>{page.hero.title}</h1>
				<p class="hero__subtitle">{page.hero.subtitle}</p>
				<div class="hero__body">
					{page.hero.body.map((paragraph) => <p>{paragraph}</p>)}
				</div>
				<div class="hero__actions">
					<a class="button button--primary" href={page.hero.primaryCta.href}>
						{page.hero.primaryCta.label}
					</a>
					{
						page.hero.secondaryCta && (
							<a class="button button--secondary" href={page.hero.secondaryCta.href}>
								{page.hero.secondaryCta.label}
							</a>
						)
					}
				</div>
			</div>

			<div class="hero__visual" aria-label="מקום לתמונת הקורס העתידית">
				<div class="course-preview">
					<div class="course-preview__screen">
						<div class="preview-toolbar">
							<span></span>
							<span></span>
							<span></span>
						</div>
						<div class="preview-stage">
							<div class="letter-bubble letter-bubble--yellow">
								<strong>A</strong>
								<span>sound</span>
							</div>
							<div class="letter-bubble letter-bubble--blue">
								<strong>sh</strong>
								<span>blend</span>
							</div>
						</div>
						<div class="preview-word">
							<strong>read</strong>
							<span>word</span>
						</div>
					</div>
					<div class="course-preview__caption">
						<strong>40 שיעורים צבעוניים</strong>
						<span>מקום לצילום מסך אמיתי מהקורס</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="stats-strip" aria-label="נתוני הקורס">
		<div class="stats-strip__inner">
			{
				page.stats.map((stat) => (
					<div class="stat">
						<strong>{stat.value}</strong>
						<span>{stat.label}</span>
					</div>
				))
			}
		</div>
	</section>

	<slot />
</main>

<style>
	.hero {
		position: relative;
		overflow: hidden;
		padding: var(--space-8) var(--space-page) var(--space-10);
		background:
			radial-gradient(circle at 18% 16%, rgba(255, 215, 63, 0.6), transparent 18rem),
			radial-gradient(circle at 82% 12%, rgba(35, 183, 216, 0.35), transparent 21rem),
			linear-gradient(180deg, #fff4c7 0%, #fff9f0 100%);
		text-align: center;
	}

	.hero::before,
	.hero::after {
		content: "";
		position: absolute;
		border-radius: 999px;
		background: rgba(255, 63, 143, 0.13);
		pointer-events: none;
	}

	.hero::before {
		width: 13rem;
		height: 13rem;
		inset-block-start: 6rem;
		inset-inline-start: -5rem;
	}

	.hero::after {
		width: 9rem;
		height: 9rem;
		inset-block-end: 4rem;
		inset-inline-end: -3rem;
	}

	.hero__inner,
	.stats-strip__inner {
		width: min(100%, var(--layout-width));
		margin-inline: auto;
	}

	.hero__inner {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(320px, 0.72fr);
		gap: var(--space-8);
		align-items: center;
		min-height: min(760px, calc(100vh - 72px));
	}

	.hero__copy {
		display: grid;
		justify-items: center;
	}

	.hero h1 {
		max-width: 820px;
		margin: 0;
		font-size: clamp(2.8rem, 2.1rem + 3vw, 5.35rem);
		line-height: 1.03;
	}

	.hero__subtitle {
		max-width: 720px;
		margin: var(--space-5) 0 0;
		color: var(--color-accent-strong);
		font-size: clamp(1.22rem, 1.1rem + 0.45vw, 1.55rem);
		line-height: 1.5;
		font-weight: 900;
	}

	.hero__body {
		max-width: 690px;
		margin-block-start: var(--space-6);
	}

	.hero__body p {
		margin: 0;
	}

	.hero__body p + p {
		margin-block-start: var(--space-4);
	}

	.hero__actions {
		justify-content: center;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		margin-block-start: var(--space-7);
	}

	.hero__visual {
		min-height: 460px;
		display: grid;
		place-items: center;
	}

	.course-preview {
		position: relative;
		width: min(100%, 430px);
		padding: var(--space-5);
		border: 6px solid white;
		border-radius: 34px;
		background: linear-gradient(180deg, #fff, #fff1d1);
		box-shadow: var(--shadow-lift);
		transform: rotate(-1.5deg);
	}

	.course-preview::before {
		content: "";
		position: absolute;
		inset: auto auto -1.25rem 2rem;
		width: 7rem;
		height: 2.4rem;
		border-radius: 999px;
		background: rgba(35, 183, 216, 0.26);
		filter: blur(2px);
	}

	.course-preview__screen {
		aspect-ratio: 1.18 / 1;
		display: grid;
		grid-template-rows: auto 1fr auto;
		gap: var(--space-4);
		padding: var(--space-5);
		border-radius: 24px;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.18)),
			linear-gradient(135deg, #b9effb, #ffe2f0 55%, #ffe678);
		color: var(--color-ink);
		direction: ltr;
	}

	.preview-toolbar {
		display: flex;
		gap: 0.45rem;
		justify-content: flex-start;
	}

	.preview-toolbar span {
		width: 0.72rem;
		height: 0.72rem;
		border-radius: 999px;
		background: rgba(38, 28, 82, 0.22);
	}

	.preview-stage {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-4);
		align-items: stretch;
	}

	.letter-bubble,
	.preview-word {
		display: grid;
		place-items: center;
		align-content: center;
		border: 4px solid white;
		border-radius: 24px;
		box-shadow: 0 10px 22px rgba(38, 28, 82, 0.14);
		text-align: center;
	}

	.letter-bubble {
		min-height: 9rem;
	}

	.letter-bubble strong {
		color: var(--color-ink);
		font-size: clamp(3.2rem, 7vw, 5.2rem);
		font-weight: 900;
		line-height: 0.95;
	}

	.letter-bubble span,
	.preview-word span {
		color: rgba(38, 28, 82, 0.62);
		font-size: 1rem;
		font-weight: 900;
	}

	.letter-bubble--yellow {
		background: #ffe778;
	}

	.letter-bubble--blue {
		background: #91e7ff;
	}

	.preview-word {
		min-height: 5.4rem;
		background: #ff9ed0;
	}

	.preview-word strong {
		color: var(--color-ink);
		font-size: clamp(2.2rem, 5vw, 3.8rem);
		font-weight: 900;
		line-height: 0.95;
	}

	.course-preview__caption {
		display: grid;
		gap: 0.2rem;
		margin-block-start: var(--space-4);
		padding: var(--space-4);
		border-radius: 20px;
		background: white;
		box-shadow: var(--shadow-soft);
		text-align: center;
	}

	.course-preview__caption strong {
		color: var(--color-accent-strong);
		font-size: 1.18rem;
	}

	.course-preview__caption span {
		color: var(--color-text-muted);
		font-size: 0.95rem;
	}

	.stats-strip {
		padding: var(--space-5) var(--space-page);
		background: linear-gradient(90deg, var(--color-accent), var(--color-secondary));
		color: var(--color-text-inverse);
	}

	.stats-strip__inner {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-3);
		background: transparent;
	}

	.stat {
		min-height: 118px;
		display: grid;
		align-content: center;
		gap: var(--space-2);
		padding: var(--space-5);
		border: 3px solid rgba(255, 255, 255, 0.72);
		border-radius: 22px;
		background: rgba(255, 255, 255, 0.16);
		text-align: center;
	}

	.stat strong {
		color: var(--color-accent-soft);
		font-size: 2.6rem;
		line-height: 1;
	}

	.stat span {
		color: color-mix(in srgb, var(--color-text-inverse) 78%, transparent);
	}

	@media (max-width: 900px) {
		.hero__inner {
			grid-template-columns: 1fr;
			min-height: auto;
		}

		.hero__visual {
			min-height: 320px;
		}

		.stats-strip__inner {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 560px) {
		.hero {
			padding-block-start: var(--space-6);
		}

		.hero__actions .button {
			width: 100%;
			justify-content: center;
		}

		.hero__visual {
			display: none;
		}

		.stats-strip__inner {
			grid-template-columns: 1fr 1fr;
		}

		.stat {
			min-height: 108px;
			padding: var(--space-4);
		}

		.stat strong {
			font-size: 1.85rem;
		}
	}
</style>
