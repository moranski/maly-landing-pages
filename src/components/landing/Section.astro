---
interface Props {
	kicker?: string;
	title: string;
	tone?: "plain" | "tinted" | "deep";
	id?: string;
}

const { kicker, title, tone = "plain", id } = Astro.props;
---

<section id={id} class:list={["section", `section--${tone}`]}>
	<div class="section__inner">
		<div class="section__header">
			{kicker && <p class="kicker">{kicker}</p>}
			<h2>{title}</h2>
		</div>
		<div class="section__content section-prose">
			<slot />
		</div>
	</div>
</section>

<style>
	.section {
		position: relative;
		overflow: hidden;
		padding: var(--space-section) var(--space-page);
		background: var(--color-surface);
	}

	.section--tinted {
		background:
			radial-gradient(circle at 12% 18%, rgba(255, 63, 143, 0.13), transparent 16rem),
			var(--color-surface-warm);
	}

	.section--deep {
		background:
			radial-gradient(circle at 80% 12%, rgba(255, 215, 63, 0.24), transparent 20rem),
			linear-gradient(135deg, var(--color-ink), #3b2075);
		color: var(--color-text-inverse);
	}

	.section__inner {
		width: min(100%, var(--layout-width));
		margin-inline: auto;
	}

	.section__header {
		max-width: 870px;
		margin-inline: auto;
		margin-block-end: var(--space-8);
		text-align: center;
	}

	.section__header h2 {
		margin: 0;
		font-size: clamp(2.15rem, 1.75rem + 1.7vw, 3.55rem);
		line-height: 1.08;
	}

	.section--deep h2 {
		color: var(--color-text-inverse);
	}

	.section__content {
		display: grid;
		gap: var(--space-6);
		justify-items: center;
	}

	.section-prose :global(p) {
		max-width: 860px;
		margin: 0;
		color: var(--color-text);
		font-size: 1.12rem;
		text-align: center;
	}

	.section-prose :global(p + p) {
		margin-block-start: calc(-1 * var(--space-3));
	}

	.section-prose :global(blockquote) {
		max-width: 860px;
		margin: 0;
		padding: var(--space-6);
		border: 0;
		border-radius: 28px;
		background: white;
		color: var(--color-ink);
		font-size: 1.35rem;
		font-weight: 800;
		text-align: center;
		box-shadow: var(--shadow-soft);
	}

	.section-prose :global(blockquote)::before {
		content: "״";
		display: block;
		margin-block-end: var(--space-2);
		color: var(--color-accent);
		font-size: 3rem;
		line-height: 0.7;
	}

	.section-prose :global(blockquote p) {
		margin: 0;
		color: inherit;
		font-size: inherit;
	}

	.section-prose :global(h3) {
		max-width: 860px;
		width: 100%;
		margin: 0 0 calc(-1 * var(--space-4));
		padding: var(--space-4) var(--space-5);
		border-radius: 18px;
		background: white;
		color: var(--color-accent-strong);
		font-size: 1.28rem;
		line-height: 1.25;
		text-align: center;
		box-shadow: var(--shadow-soft);
	}

	.kicker {
		margin: 0 0 var(--space-3);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.4rem 1rem;
		border-radius: var(--radius-pill);
		background: white;
		color: var(--color-secondary-strong);
		font-size: var(--font-size-small);
		font-weight: 900;
		letter-spacing: 0;
		box-shadow: var(--shadow-soft);
	}

	.section--deep .kicker {
		color: var(--color-accent-soft);
	}
</style>
