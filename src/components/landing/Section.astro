---
interface Props {
	kicker?: string;
	title: string;
	tone?: "plain" | "tinted" | "deep";
	id?: string;
}

const { kicker, title, tone = "plain", id } = Astro.props;
---

<section id={id} class:list={["section", `section--${tone}`]}>
	<div class="section__inner">
		<div class="section__header">
			{kicker && <p class="kicker">{kicker}</p>}
			<h2>{title}</h2>
		</div>
		<div class="section__content section-prose">
			<slot />
		</div>
	</div>
</section>

<style>
	.section {
		padding: var(--space-section) var(--space-page);
	}

	.section--tinted {
		background: var(--color-surface-warm);
	}

	.section--deep {
		background: var(--color-ink);
		color: var(--color-text-inverse);
	}

	.section__inner {
		width: min(100%, var(--layout-width));
		margin-inline: auto;
	}

	.section__header {
		max-width: 760px;
		margin-block-end: var(--space-8);
	}

	.section__header h2 {
		margin: 0;
		font-size: clamp(2rem, 1.7rem + 1.4vw, 3.1rem);
		line-height: 1.12;
	}

	.section--deep h2 {
		color: var(--color-text-inverse);
	}

	.section__content {
		display: grid;
		gap: var(--space-6);
	}

	.section-prose :global(p) {
		max-width: 860px;
		margin: 0;
		color: var(--color-text);
		font-size: 1.12rem;
	}

	.section-prose :global(p + p) {
		margin-block-start: calc(-1 * var(--space-3));
	}

	.section-prose :global(blockquote) {
		max-width: 860px;
		margin: 0;
		padding: var(--space-5);
		border-inline-start: 5px solid var(--color-accent);
		border-radius: var(--radius-card);
		background: var(--color-surface-warm);
		color: var(--color-ink);
		font-size: 1.35rem;
		font-weight: 800;
	}

	.section-prose :global(blockquote p) {
		margin: 0;
		color: inherit;
		font-size: inherit;
	}

	.section-prose :global(h3) {
		max-width: 860px;
		margin: var(--space-2) 0 calc(-1 * var(--space-4));
		padding-block-start: var(--space-3);
		color: var(--color-ink);
		font-size: 1.25rem;
		line-height: 1.25;
	}

	.kicker {
		margin: 0 0 var(--space-3);
		color: var(--color-accent-strong);
		font-size: var(--font-size-small);
		font-weight: 800;
		letter-spacing: 0;
	}

	.section--deep .kicker {
		color: var(--color-accent-soft);
	}
</style>
