---
interface Props {
	cta: {
		label: string;
		href: string;
	};
}

const { cta } = Astro.props;
---

<div class="sticky-cta" aria-label="פעולה ראשית">
	<a class="button button--primary" href={cta.href}>{cta.label}</a>
</div>

<style>
	.sticky-cta {
		position: fixed;
		inset-inline: 0;
		inset-block-end: 0;
		z-index: 20;
		display: none;
		padding: var(--space-3) var(--space-page);
		background: color-mix(in srgb, var(--color-surface) 92%, transparent);
		border-block-start: 1px solid var(--color-border);
		backdrop-filter: blur(14px);
	}

	.sticky-cta .button {
		width: 100%;
		justify-content: center;
	}

	@media (max-width: 760px) {
		.sticky-cta {
			display: block;
		}
	}
</style>
