---
interface Props {
	cta: {
		label: string;
		href: string;
	};
}

const { cta } = Astro.props;
---

<div class="sticky-cta" aria-label="פעולה ראשית">
	<a class="button button--primary" href={cta.href}>{cta.label}</a>
</div>

<style>
	.sticky-cta {
		position: fixed;
		inset-inline: 0;
		inset-block-end: 0;
		z-index: 20;
		display: none;
		padding: var(--space-3) var(--space-page) calc(var(--space-3) + env(safe-area-inset-bottom));
		background: rgba(255, 249, 240, 0.92);
		border-block-start: 3px solid rgba(255, 63, 143, 0.22);
		backdrop-filter: blur(14px);
		box-shadow: 0 -12px 26px rgba(38, 28, 82, 0.12);
	}

	.sticky-cta .button {
		width: 100%;
		justify-content: center;
	}

	@media (max-width: 760px) {
		.sticky-cta {
			display: block;
		}
	}
</style>
